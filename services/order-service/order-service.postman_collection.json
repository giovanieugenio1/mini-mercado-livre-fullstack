{
  "info": {
    "name": "Mini Mercado Livre — order-service",
    "_postman_id": "e5f6a7b8-c9d0-1234-ef01-234567890abc",
    "description": "API de pedidos do Mini Mercado Livre.\nBase URL: {{base_url}} (default: http://localhost:8082)\n\nAutenticação: Bearer JWT no header Authorization.\nUse a variável {{token}} com o access_token obtido do Keycloak.\n\nFluxo sugerido:\n1. Criar pedido (01) → salva {{ultimo_pedido_id}} e {{ultimo_customer_id}}\n2. Buscar por ID (05)\n3. Cancelar pedido (13) — disponível somente no status CREATED\n4. Listar todos (08), por customer (10), por status (11)\n5. Testar erros 400/401/404 (02, 03, 04, 06, 07)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8082",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string",
      "description": "Access token JWT do Keycloak. Cole aqui ou obtenha via request de autenticação."
    },
    {
      "key": "ultimo_pedido_id",
      "value": "",
      "type": "string",
      "description": "Preenchido automaticamente pelo script de 'Criar Pedido'"
    },
    {
      "key": "ultimo_customer_id",
      "value": "",
      "type": "string",
      "description": "Preenchido automaticamente pelo script de 'Criar Pedido'"
    }
  ],
  "item": [
    {
      "name": "Pedidos",
      "item": [

        {
          "name": "01 — Criar pedido (201 Created)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201 Created', () => {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Header Location presente', () => {",
                  "    pm.expect(pm.response.headers.get('Location')).to.include('/orders/');",
                  "});",
                  "",
                  "pm.test('Body contém campos obrigatórios', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('id');",
                  "    pm.expect(body).to.have.property('customerId');",
                  "    pm.expect(body).to.have.property('status');",
                  "    pm.expect(body).to.have.property('totalAmount');",
                  "    pm.expect(body).to.have.property('currency');",
                  "    pm.expect(body).to.have.property('items');",
                  "    pm.expect(body).to.have.property('createdAt');",
                  "});",
                  "",
                  "pm.test('Status inicial é CREATED', () => {",
                  "    pm.expect(pm.response.json().status).to.equal('CREATED');",
                  "});",
                  "",
                  "pm.test('currency é BRL', () => {",
                  "    pm.expect(pm.response.json().currency).to.equal('BRL');",
                  "});",
                  "",
                  "pm.test('totalAmount calculado corretamente', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.totalAmount).to.be.above(0);",
                  "});",
                  "",
                  "pm.test('items tem 2 elementos', () => {",
                  "    pm.expect(pm.response.json().items).to.have.lengthOf(2);",
                  "});",
                  "",
                  "pm.test('lineTotal calculado por item', () => {",
                  "    const items = pm.response.json().items;",
                  "    items.forEach(item => {",
                  "        pm.expect(item).to.have.property('lineTotal');",
                  "        pm.expect(item.lineTotal).to.be.above(0);",
                  "    });",
                  "});",
                  "",
                  "// Salva IDs para requests seguintes",
                  "const body = pm.response.json();",
                  "if (body.id) {",
                  "    pm.collectionVariables.set('ultimo_pedido_id', body.id);",
                  "    console.log('Pedido criado:', body.id);",
                  "}",
                  "if (body.customerId) {",
                  "    pm.collectionVariables.set('ultimo_customer_id', body.customerId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerId\": \"a1b2c3d4-e5f6-7890-abcd-ef1234567890\",\n  \"items\": [\n    {\n      \"productId\": \"11111111-1111-1111-1111-111111111111\",\n      \"productTitle\": \"iPhone 15 Pro\",\n      \"unitPrice\": 7999.99,\n      \"quantity\": 2\n    },\n    {\n      \"productId\": \"22222222-2222-2222-2222-222222222222\",\n      \"productTitle\": \"AirPods Pro\",\n      \"unitPrice\": 1799.90,\n      \"quantity\": 1\n    }\n  ]\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/orders",
              "host": ["{{base_url}}"],
              "path": ["orders"]
            }
          }
        },

