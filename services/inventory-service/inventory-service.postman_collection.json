{
  "info": {
    "name": "inventory-service",
    "description": "Mini Mercado Livre — Inventory Service API (porta 8084)\n\nAutenticação:\n- Leitura: qualquer JWT válido (ROLE_USER)\n- Escrita: ROLE_ADMIN → use {{admin_token}} (admin1/admin1pass)\n\nFuncionalidades:\n- Consultar estoque por produto\n- Listar todos os estoques (paginado)\n- Cadastrar estoque inicial de um produto (ROLE_ADMIN)\n- Atualizar quantidade disponível (ROLE_ADMIN)\n- Consultar reservas por pedido",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Auto-obter token do Keycloak se expirado",
          "const tokenUrl = 'http://localhost:8080/realms/mini-mercado-livre/protocol/openid-connect/token';",
          "const clientId = 'mini-ml-frontend';",
          "const username = 'user1';",
          "const password = 'user1pass';",
          "",
          "const expiresAt = pm.collectionVariables.get('token_expires_at');",
          "const now = Date.now();",
          "",
          "if (!expiresAt || now >= parseInt(expiresAt)) {",
          "    pm.sendRequest({",
          "        url: tokenUrl,",
          "        method: 'POST',",
          "        header: { 'Content-Type': 'application/x-www-form-urlencoded' },",
          "        body: {",
          "            mode: 'urlencoded',",
          "            urlencoded: [",
          "                { key: 'grant_type', value: 'password' },",
          "                { key: 'client_id', value: clientId },",
          "                { key: 'username', value: username },",
          "                { key: 'password', value: password }",
          "            ]",
          "        }",
          "    }, (err, res) => {",
          "        if (err) { console.error('Erro ao obter token:', err); return; }",
          "        const body = res.json();",
          "        pm.collectionVariables.set('access_token', body.access_token);",
          "        pm.collectionVariables.set('token_expires_at', now + (body.expires_in - 30) * 1000);",
          "        console.log('Token renovado com sucesso');",
          "    });",
          "}"
        ]
      }
    }
  ],
  "variable": [
    { "key": "base_url",          "value": "http://localhost:8084" },
    { "key": "access_token",      "value": "" },
    { "key": "admin_token",       "value": "", "description": "JWT de admin1/admin1pass (ROLE_ADMIN)" },
    { "key": "token_expires_at",  "value": "0" },
    { "key": "product_id_1",      "value": "11111111-1111-1111-1111-111111111111" },
    { "key": "product_id_2",      "value": "22222222-2222-2222-2222-222222222222" },
    { "key": "product_id_3",      "value": "33333333-3333-3333-3333-333333333333" },
    { "key": "novo_produto_id",   "value": "", "description": "UUID de um novo produto a ser cadastrado no inventário" },
    { "key": "order_id",          "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /actuator/health",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/actuator/health",
            "description": "Verifica o status do serviço"
          }
        },
        {
          "name": "GET /actuator/prometheus",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/actuator/prometheus",
            "description": "Métricas Prometheus"
          }
        }
      ]
    },
    {
      "name": "Estoque (Inventory)",
      "item": [
        {
          "name": "GET /inventory/{productId} — produto com estoque",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/inventory/{{product_id_1}}",
              "host": ["{{base_url}}"],
              "path": ["inventory", "{{product_id_1}}"]
            },
            "description": "Retorna o estoque do produto 1 (seedado com 100 unidades)"
          }
        },
        {
          "name": "GET /inventory/{productId} — produto 2",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/inventory/{{product_id_2}}",
              "host": ["{{base_url}}"],
              "path": ["inventory", "{{product_id_2}}"]
            },
            "description": "Retorna o estoque do produto 2 (seedado com 50 unidades)"
          }
        },
        {
          "name": "GET /inventory/{productId} — produto 3",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/inventory/{{product_id_3}}",
              "host": ["{{base_url}}"],
              "path": ["inventory", "{{product_id_3}}"]
            },
            "description": "Retorna o estoque do produto 3 (seedado com 200 unidades)"
          }
        },
        {
          "name": "GET /inventory/{productId} — produto não existente (404)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/inventory/00000000-0000-0000-0000-000000000000",
              "host": ["{{base_url}}"],
              "path": ["inventory", "00000000-0000-0000-0000-000000000000"]
            },
            "description": "Produto não cadastrado no inventário → 404 Not Found com ProblemDetail"
          }
        },
        {
          "name": "GET /inventory — lista paginada",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/inventory?page=0&size=20",
              "host": ["{{base_url}}"],
              "path": ["inventory"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "20" }
              ]
            },
            "description": "Lista paginada de todos os estoques"
          }
        },
        {
          "name": "GET /inventory — sem autenticação (401)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": "{{base_url}}/inventory",
            "description": "Deve retornar 401 Unauthorized"
          }
        }
      ]
    },
    {
      "name": "Gestão de Estoque (ROLE_ADMIN)",
      "item": [
        {
          "name": "POST /inventory — cadastrar estoque inicial (201/200)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
                  "",
                  "pm.test('Estoque criado corretamente', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('productId');",
                  "    pm.expect(body.availableQty).to.equal(150);",
                  "    pm.expect(body.reservedQty).to.equal(0);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"{{novo_produto_id}}\",\n  \"availableQty\": 150\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/inventory",
              "host": ["{{base_url}}"],
              "path": ["inventory"]
            },
            "description": "Cadastra estoque inicial de um novo produto. Defina {{novo_produto_id}} com um UUID válido."
          }
        },
        {
          "name": "POST /inventory — produto já existe (409 Conflict)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 409 Conflict', () => pm.response.to.have.status(409));",
                  "",
                  "pm.test('Retorna ProblemDetail', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.status).to.equal(409);",
                  "    pm.expect(body.title).to.equal('Operação inválida');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"11111111-1111-1111-1111-111111111111\",\n  \"availableQty\": 100\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/inventory",
              "host": ["{{base_url}}"],
              "path": ["inventory"]
            },
            "description": "Tenta criar estoque para produto já cadastrado → 409 Conflict"
          }
        },
        {
          "name": "POST /inventory — sem ROLE_ADMIN (403 Forbidden)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 403 Forbidden', () => pm.response.to.have.status(403));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"44444444-4444-4444-4444-444444444444\",\n  \"availableQty\": 10\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/inventory",
              "host": ["{{base_url}}"],
              "path": ["inventory"]
            },
            "description": "ROLE_USER não tem permissão para criar estoque → 403"
          }
        },
        {
          "name": "PUT /inventory/{productId} — atualizar quantidade",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
                  "",
                  "pm.test('Quantidade atualizada', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.availableQty).to.equal(200);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"availableQty\": 200\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/inventory/{{product_id_1}}",
              "host": ["{{base_url}}"],
              "path": ["inventory", "{{product_id_1}}"]
            },
            "description": "Redefine a quantidade disponível do produto 1 para 200"
          }
        },
        {
          "name": "PUT /inventory/{productId} — produto não existe (404)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 404 Not Found', () => pm.response.to.have.status(404));",
                  "",
                  "pm.test('Retorna ProblemDetail', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.title).to.equal('Produto não encontrado no inventário');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"availableQty\": 50\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/inventory/00000000-0000-0000-0000-000000000000",
              "host": ["{{base_url}}"],
              "path": ["inventory", "00000000-0000-0000-0000-000000000000"]
            },
            "description": "Produto não cadastrado → 404 Not Found"
          }
        }
      ]
    },
    {
      "name": "Reservas (Reservations)",
      "item": [
        {
          "name": "GET /reservations/order/{orderId} — reserva existente",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/reservations/order/{{order_id}}",
              "host": ["{{base_url}}"],
              "path": ["reservations", "order", "{{order_id}}"]
            },
            "description": "Busca reserva pelo orderId. Defina {{order_id}} com um orderId que passou pelo fluxo completo (order → payment.authorized → inventory.reserved)"
          }
        },
        {
          "name": "GET /reservations/order/{orderId} — reserva não encontrada (404)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/reservations/order/00000000-0000-0000-0000-000000000000",
              "host": ["{{base_url}}"],
              "path": ["reservations", "order", "00000000-0000-0000-0000-000000000000"]
            },
            "description": "Deve retornar 404 com ProblemDetail: title=Reserva não encontrada"
          }
        }
      ]
    },
    {
      "name": "Fluxo Completo (Saga)",
      "item": [
        {
          "name": "1. [order-service] POST /orders — criar pedido",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "http://localhost:8082/orders",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerId\": \"aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa\",\n  \"items\": [\n    {\n      \"productId\": \"11111111-1111-1111-1111-111111111111\",\n      \"productName\": \"Notebook Pro\",\n      \"quantity\": 2,\n      \"unitPrice\": 1500.00\n    },\n    {\n      \"productId\": \"22222222-2222-2222-2222-222222222222\",\n      \"productName\": \"Mouse Gamer\",\n      \"quantity\": 1,\n      \"unitPrice\": 250.00\n    }\n  ]\n}"
            },
            "description": "Passo 1: Cria o pedido no order-service (total = 3250.00 → dentro do limite de 50000 → payment irá autorizar)"
          }
        },
        {
          "name": "2. [payment-service] GET /payments/order/{orderId}",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": "http://localhost:8083/payments/order/{{order_id}}",
            "description": "Passo 2: Verificar se o pagamento foi autorizado (aguardar ~2s para o outbox publicar)"
          }
        },
        {
          "name": "3. [inventory-service] GET /reservations/order/{orderId}",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": "{{base_url}}/reservations/order/{{order_id}}",
            "description": "Passo 3: Verificar se o estoque foi reservado (aguardar ~2s para payment outbox publicar)"
          }
        },
        {
          "name": "4. [inventory-service] GET /inventory — ver estoque atualizado",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": "{{base_url}}/inventory?page=0&size=20",
            "description": "Passo 4: Ver estoques atualizados após a reserva (qty devem ter diminuído)"
          }
        }
      ]
    }
  ]
}
