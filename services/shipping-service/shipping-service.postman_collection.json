{
  "info": {
    "name": "shipping-service",
    "description": "Mini Mercado Livre — Shipping Service API (porta 8085)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const tokenUrl = 'http://localhost:8080/realms/mini-mercado-livre/protocol/openid-connect/token';",
          "const clientId = 'mini-ml-frontend';",
          "const username = 'user1';",
          "const password = 'user1pass';",
          "const expiresAt = pm.collectionVariables.get('token_expires_at');",
          "const now = Date.now();",
          "if (!expiresAt || now >= parseInt(expiresAt)) {",
          "    pm.sendRequest({",
          "        url: tokenUrl,",
          "        method: 'POST',",
          "        header: { 'Content-Type': 'application/x-www-form-urlencoded' },",
          "        body: {",
          "            mode: 'urlencoded',",
          "            urlencoded: [",
          "                { key: 'grant_type', value: 'password' },",
          "                { key: 'client_id',  value: clientId },",
          "                { key: 'username',   value: username },",
          "                { key: 'password',   value: password }",
          "            ]",
          "        }",
          "    }, (err, res) => {",
          "        if (err) { console.error('Erro ao obter token:', err); return; }",
          "        const body = res.json();",
          "        pm.collectionVariables.set('access_token', body.access_token);",
          "        pm.collectionVariables.set('token_expires_at', now + (body.expires_in - 30) * 1000);",
          "        console.log('Token renovado com sucesso');",
          "    });",
          "}"
        ]
      }
    }
  ],
  "variable": [
    { "key": "base_url",         "value": "http://localhost:8085" },
    { "key": "access_token",     "value": "" },
    { "key": "token_expires_at", "value": "0" },
    { "key": "order_id",         "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /actuator/health",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/actuator/health",
            "description": "Verifica o status do serviço"
          }
        },
        {
          "name": "GET /actuator/prometheus",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/actuator/prometheus",
            "description": "Métricas Prometheus"
          }
        }
      ]
    },
    {
      "name": "Envios (Shippings)",
      "item": [
        {
          "name": "GET /shippings/order/{orderId} — envio existente",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Accept",        "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/shippings/order/{{order_id}}",
              "host": ["{{base_url}}"],
              "path": ["shippings", "order", "{{order_id}}"]
            },
            "description": "Retorna o envio associado ao pedido. Defina {{order_id}} com o ID de um pedido que passou pelo fluxo completo (order → payment.authorized → inventory.reserved → shipping.created)."
          }
        },
        {
          "name": "GET /shippings/order/{orderId} — envio não encontrado (404)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Accept",        "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/shippings/order/00000000-0000-0000-0000-000000000000",
              "host": ["{{base_url}}"],
              "path": ["shippings", "order", "00000000-0000-0000-0000-000000000000"]
            },
            "description": "Deve retornar 404 com ProblemDetail: title=Envio não encontrado"
          }
        },
        {
          "name": "GET /shippings — lista paginada",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Accept",        "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/shippings?page=0&size=20",
              "host": ["{{base_url}}"],
              "path": ["shippings"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "20" }
              ]
            },
            "description": "Lista paginada de todos os envios"
          }
        },
        {
          "name": "GET /shippings — sem autenticação (401)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{base_url}}/shippings",
            "description": "Deve retornar 401 Unauthorized"
          }
        }
      ]
    },
    {
      "name": "Fluxo Completo da Saga",
      "item": [
        {
          "name": "1. [order-service] POST /orders",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": "http://localhost:8082/orders",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerId\": \"aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa\",\n  \"items\": [\n    {\n      \"productId\": \"11111111-1111-1111-1111-111111111111\",\n      \"productName\": \"Notebook Pro\",\n      \"quantity\": 1,\n      \"unitPrice\": 3500.00\n    },\n    {\n      \"productId\": \"22222222-2222-2222-2222-222222222222\",\n      \"productName\": \"Mouse Gamer\",\n      \"quantity\": 2,\n      \"unitPrice\": 150.00\n    }\n  ]\n}"
            },
            "description": "Passo 1: Cria pedido (total = 3800.00 BRL → payment autoriza → inventory reserva → shipping cria)"
          }
        },
        {
          "name": "2. [order-service] GET /orders/{orderId} — status INVENTORY_RESERVED",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "http://localhost:8082/orders/{{order_id}}",
            "description": "Passo 2: Verificar se o pedido chegou a INVENTORY_RESERVED (aguardar ~3s)"
          }
        },
        {
          "name": "3. [inventory-service] GET /reservations/order/{orderId}",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "http://localhost:8084/reservations/order/{{order_id}}",
            "description": "Passo 3: Verificar reserva de estoque"
          }
        },
        {
          "name": "4. [shipping-service] GET /shippings/order/{orderId}",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/shippings/order/{{order_id}}",
            "description": "Passo 4: Verificar envio criado (aguardar ~2s após inventory.reserved ser publicado)"
          }
        },
        {
          "name": "5. [order-service] GET /orders/{orderId} — status COMPLETED",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "http://localhost:8082/orders/{{order_id}}",
            "description": "Passo 5: Verificar pedido COMPLETED (aguardar ~2s após shipping.created ser publicado)"
          }
        }
      ]
    }
  ]
}
