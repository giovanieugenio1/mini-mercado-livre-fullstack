        {
          "name": "07 — Listar todos os pagamentos (paginação default)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', () => {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Resposta tem estrutura de paginação', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('content');",
                  "    pm.expect(body).to.have.property('page');",
                  "    pm.expect(body).to.have.property('size');",
                  "    pm.expect(body).to.have.property('totalElements');",
                  "    pm.expect(body).to.have.property('totalPages');",
                  "    pm.expect(body).to.have.property('last');",
                  "    pm.expect(body.content).to.be.an('array');",
                  "    pm.expect(body.page).to.equal(0);",
                  "});",
                  "",
                  "pm.test('Cada item tem amount, status e orderId', () => {",
                  "    const items = pm.response.json().content;",
                  "    items.forEach(p => {",
                  "        pm.expect(p).to.have.property('id');",
                  "        pm.expect(p).to.have.property('orderId');",
                  "        pm.expect(p).to.have.property('amount');",
                  "        pm.expect(p).to.have.property('status');",
                  "    });",
                  "});"
                ],
