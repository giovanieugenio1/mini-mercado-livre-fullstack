{
  "id": "mini-mercado-livre",
  "realm": "mini-mercado-livre",
  "displayName": "Mini Mercado Livre",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": false,

  "accessTokenLifespan": 3600,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "offlineSessionIdleTimeout": 2592000,

  "clients": [
    {
      "clientId": "mini-ml-frontend",
      "name": "Mini ML Frontend (Angular)",
      "description": "Cliente público para o Angular SPA com PKCE",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "bearerOnly": false,
      "consentRequired": false,
      "fullScopeAllowed": true,
      "redirectUris": [
        "http://localhost:4200/*",
        "http://localhost:4200",
        "http://127.0.0.1:4200/*"
      ],
      "webOrigins": [
        "http://localhost:4200",
        "http://127.0.0.1:4200"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:4200/*"
      },
      "protocolMappers": [
        {
          "name": "realm-roles-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "roles",
            "jsonType.label": "String"
          }
        }
      ]
    },
    {
      "clientId": "mini-ml-services",
      "name": "Mini ML Services (M2M)",
      "description": "Cliente confidencial para comunicação serviço-a-serviço",
      "enabled": true,
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "mini-ml-services-secret",
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "authorizationServicesEnabled": false,
      "bearerOnly": false,
      "consentRequired": false,
      "fullScopeAllowed": true,
      "attributes": {}
    }
  ],

  "roles": {
    "realm": [
      {
        "name": "ROLE_USER",
        "description": "Comprador — acesso padrão ao marketplace"
      },
      {
        "name": "ROLE_ADMIN",
        "description": "Administrador — gerencia catálogo e pedidos"
      }
    ]
  },

  "scopeMappings": [],
  "clientScopeMappings": {},

  "users": [
    {
      "username": "user1",
      "enabled": true,
      "emailVerified": true,
      "email": "user1@example.com",
      "firstName": "Usuario",
      "lastName": "Um",
      "credentials": [
        {
          "type": "password",
          "value": "user1pass",
          "temporary": false
        }
      ],
      "realmRoles": ["ROLE_USER"]
    },
    {
      "username": "admin1",
      "enabled": true,
      "emailVerified": true,
      "email": "admin1@example.com",
      "firstName": "Admin",
      "lastName": "Um",
      "credentials": [
        {
          "type": "password",
          "value": "admin1pass",
          "temporary": false
        }
      ],
      "realmRoles": ["ROLE_USER", "ROLE_ADMIN"]
    }
  ],

  "defaultRoles": ["ROLE_USER"],

  "internationalizationEnabled": false,
  "supportedLocales": ["pt-BR", "en"],
  "defaultLocale": "pt-BR"
}
