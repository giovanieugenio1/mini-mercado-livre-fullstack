{
    "version": "0.2.0",
    "configurations": [

        // ── catalog-service ────────────────────────────────────────
        {
            "type": "java",
            "name": "catalog-service (Run)",
            "request": "launch",
            "mainClass": "com.miniml.catalog.CatalogServiceApplication",
            "projectName": "catalog-service",
            "envFile": "${workspaceFolder}/services/catalog-service/.env",
            "vmArgs": "-Dspring.profiles.active=default"
        },
        {
            "type": "java",
            "name": "catalog-service (Debug)",
            "request": "launch",
            "mainClass": "com.miniml.catalog.CatalogServiceApplication",
            "projectName": "catalog-service",
            "envFile": "${workspaceFolder}/services/catalog-service/.env",
            "vmArgs": "-Dspring.profiles.active=default -Xdebug -agentlib:jdwp=transport=dt_socket,server=y,suspend=y,address=*:5081"
        },
        {
            "type": "java",
            "name": "catalog-service (Attach :5081)",
            "request": "attach",
            "hostName": "localhost",
            "port": 5081
        },

        // ── order-service ──────────────────────────────────────────
        {
            "type": "java",
            "name": "order-service (Run)",
            "request": "launch",
            "mainClass": "com.miniml.order.OrderServiceApplication",
            "projectName": "order-service",
            "envFile": "${workspaceFolder}/services/order-service/.env",
            "vmArgs": "-Dspring.profiles.active=default"
        },
        {
            "type": "java",
            "name": "order-service (Debug)",
            "request": "launch",
            "mainClass": "com.miniml.order.OrderServiceApplication",
            "projectName": "order-service",
            "envFile": "${workspaceFolder}/services/order-service/.env",
            "vmArgs": "-Dspring.profiles.active=default -Xdebug -agentlib:jdwp=transport=dt_socket,server=y,suspend=y,address=*:5082"
        },
        {
            "type": "java",
            "name": "order-service (Attach :5082)",
            "request": "attach",
            "hostName": "localhost",
            "port": 5082
        },

        // ── payment-service ────────────────────────────────────────
        {
            "type": "java",
            "name": "payment-service (Run)",
            "request": "launch",
            "mainClass": "com.miniml.payment.PaymentServiceApplication",
            "projectName": "payment-service",
            "vmArgs": "-Dspring.profiles.active=default"
        },
        {
            "type": "java",
            "name": "payment-service (Attach :5083)",
            "request": "attach",
            "hostName": "localhost",
            "port": 5083
        },

        // ── inventory-service ──────────────────────────────────────
        {
            "type": "java",
            "name": "inventory-service (Run)",
            "request": "launch",
            "mainClass": "com.miniml.inventory.InventoryServiceApplication",
            "projectName": "inventory-service",
            "vmArgs": "-Dspring.profiles.active=default"
        },
        {
            "type": "java",
            "name": "inventory-service (Attach :5084)",
            "request": "attach",
            "hostName": "localhost",
            "port": 5084
        },

        // ── shipping-service ───────────────────────────────────────
        {
            "type": "java",
            "name": "shipping-service (Run)",
            "request": "launch",
            "mainClass": "com.miniml.shipping.ShippingServiceApplication",
            "projectName": "shipping-service",
            "vmArgs": "-Dspring.profiles.active=default"
        },
        {
            "type": "java",
            "name": "shipping-service (Attach :5085)",
            "request": "attach",
            "hostName": "localhost",
            "port": 5085
        },

        // ── notification-service ───────────────────────────────────
        {
            "type": "java",
            "name": "notification-service (Run)",
            "request": "launch",
            "mainClass": "com.miniml.notification.NotificationServiceApplication",
            "projectName": "notification-service",
            "vmArgs": "-Dspring.profiles.active=default"
        },
        {
            "type": "java",
            "name": "notification-service (Attach :5086)",
            "request": "attach",
            "hostName": "localhost",
            "port": 5086
        }

    ],

    "compounds": [

        // Sobe catalog + order juntos (útil para testar o fluxo de pedido)
        {
            "name": "catalog + order",
            "configurations": [
                "catalog-service (Run)",
                "order-service (Run)"
            ],
            "stopAll": true
        },

        // Sobe todos os serviços de backend de uma vez
        {
            "name": "All services",
            "configurations": [
                "catalog-service (Run)",
                "order-service (Run)",
                "payment-service (Run)",
                "inventory-service (Run)",
                "shipping-service (Run)",
                "notification-service (Run)"
            ],
            "stopAll": true
        }

    ]
}
